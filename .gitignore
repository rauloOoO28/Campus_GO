# ============================================================
# .gitignore para CampusGo (Django + Python)
# ============================================================
 
# Entornos virtuales
venv/
env/
.venv/
ENV/
.python-version
 
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
build/
dist/
 
# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
 
# Archivos subidos por usuarios y QR generados
# (cada dev los regenera localmente con: python manage.py cargar_escom --con-qr)
media/
 
# Archivos estáticos recolectados (solo en producción)
staticfiles/
/static_root/
 
# Variables de entorno
.env
.env.local
.env.*.local
 
# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
 
# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini
 
# Tests / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
 
# Jupyter
.ipynb_checkpoints/
 
# Node (por si usan algo de frontend después)
node_modules/
npm-debug.log*